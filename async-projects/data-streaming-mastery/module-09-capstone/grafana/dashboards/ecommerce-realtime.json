          "rawSql": "SELECT\n  window_start AS \"time\",\n  order_count AS \"Orders\",\n  total_revenue AS \"Revenue ($)\"\nFROM revenue_per_minute\nWHERE window_start >= NOW() - INTERVAL '30 minutes'\nORDER BY window_start;",
